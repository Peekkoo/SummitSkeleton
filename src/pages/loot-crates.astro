---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/loot-crates.css';
---

<BaseLayout title="Loot Crates - Summit">
<main class="crates-shell">
    <nav class="loot-crates-navigation" aria-label="Loot crates navigation">
        <a class="brand" href="/">
            <h1>Summit</h1>
        </a>
        <div class="navigation-actions">
            <a class="navigation-link" href="/dashboard">Dashboard</a>
            <a class="navigation-link" href="/leaderboard">Leaderboard</a>
            <a class="navigation-link" href="/credits">Credits</a>
        </div>
    </nav>

    <section class="hero-panel" aria-labelledby="crates-title">
        <div class="hero-copy">
            <span class="eyebrow">Loot Crates</span>
            <h2 id="crates-title">Spend credits, open rewards</h2>
            <p>Use credits earned through Summit to buy loot crates. Open crates for XP boosts, bonus credits, and future reward types.</p>
            <div class="hero-actions">
                <a class="primary-action" href="#crate-shop">Buy Crate</a>
                <a class="ghost-action" href="/dashboard">Back to Dashboard</a>
            </div>
        </div>

        <aside class="wallet-panel" aria-label="Your wallet">
            <span class="panel-label">Your Wallet</span>
            <div class="wallet-grid">
                <div class="wallet-item">
                    <span class="statistic-label">Credits</span>
                    <strong id="credits-value">0</strong>
                </div>
                <div class="wallet-item">
                    <span class="statistic-label">Crates</span>
                    <strong id="lootbox-value">0</strong>
                </div>
            </div>
        </aside>
    </section>

    <section class="statistics-grid" aria-label="Account reward stats">
        <article class="statistic-card">
            <span class="statistic-label">Level</span>
            <strong id="level-value">1</strong>
        </article>
        <article class="statistic-card">
            <span class="statistic-label">XP</span>
            <strong id="xp-value">0</strong>
        </article>
        <article class="statistic-card">
            <span class="statistic-label">Streak</span>
            <strong><span id="streak-value">0</span>d</strong>
        </article>
    </section>

    <div class="crates-grid">
        <section class="crate-card" id="crate-shop" aria-labelledby="shop-title">
            <div class="crate-visual" id="crate-visual" aria-hidden="true">
                <div class="crate-object">
                    <span class="crate-lid"></span>
                    <span class="crate-body"></span>
                    <span class="crate-band vertical"></span>
                    <span class="crate-band horizontal"></span>
                    <span class="crate-lock">$</span>
                    <span class="crate-spark one"></span>
                    <span class="crate-spark two"></span>
                    <span class="crate-spark three"></span>
                    <span class="crate-spark four"></span>
                </div>
            </div>
            <span class="crate-metadata">75 credits each</span>
            <h3 id="shop-title">Summit Supply Crate</h3>
            <p>Buy one crate for 75 credits, then open it when you are ready. Rewards are saved to the current local account.</p>
            <div class="crate-actions">
                <button class="crate-button" id="buy-crate" type="button">Buy Crate</button>
                <button class="ghost-action" id="open-crate" type="button">Open Crate</button>
            </div>
            <div class="result-panel hidden" id="result-panel" aria-live="polite">
                <span class="reward-label">Result</span>
                <h3 id="result-title">Ready</h3>
                <p id="result-copy">Buy or open a crate to see what happens.</p>
            </div>
        </section>

        <aside class="result-panel" aria-labelledby="rewards-title">
            <span class="panel-label">Possible Rewards</span>
            <h3 id="rewards-title">What can drop?</h3>
            <div class="rewards-grid">
                <article class="reward-card">
                    <strong>XP Boosts</strong>
                    <p>+50, +100, or jackpot +200 XP.</p>
                </article>
                <article class="reward-card">
                    <strong>Credit Drops</strong>
                    <p>Earn back +25 or +50 credits.</p>
                </article>
                <article class="reward-card">
                    <strong>More Later</strong>
                    <p>Badges, cosmetics, and study boosts can plug in here later.</p>
                </article>
            </div>
        </aside>
    </div>
</main>

<script>
    import { buyLootbox, getCurrentUser, openLootbox } from '../scripts/auth.js';

    const CRATE_COST = 75;
    let animationTimer;

    function getPage() {
        return {
            creditsValue: document.getElementById('credits-value'),
            lootboxValue: document.getElementById('lootbox-value'),
            levelValue: document.getElementById('level-value'),
            xpValue: document.getElementById('xp-value'),
            streakValue: document.getElementById('streak-value'),
            buyButton: document.getElementById('buy-crate') as HTMLButtonElement,
            openButton: document.getElementById('open-crate') as HTMLButtonElement,
            crateVisual: document.getElementById('crate-visual'),
            resultPanel: document.getElementById('result-panel'),
            resultTitle: document.getElementById('result-title'),
            resultCopy: document.getElementById('result-copy'),
        };
    }

    function format(value) {
        return Number(value ?? 0).toLocaleString();
    }

    function setResult(page, type, title, copy) {
        if (!page.resultPanel || !page.resultTitle || !page.resultCopy) return;
        page.resultPanel.classList.remove('hidden', 'success', 'error');
        page.resultPanel.classList.add(type);
        page.resultTitle.textContent = title;
        page.resultCopy.textContent = copy;
    }

    function animateCrate(page, state) {
        if (!page.crateVisual) return;
        page.crateVisual.classList.remove('buying', 'opening', 'opened');
        void page.crateVisual.offsetWidth;
        page.crateVisual.classList.add(state);
    }

    function finishAnimationSoon(callback) {
        window.clearTimeout(animationTimer);
        animationTimer = window.setTimeout(callback, 1050);
    }

    function renderUser(user = getCurrentUser()) {
        const page = getPage();
        if (!page.buyButton || !page.openButton) return;

        if (!user) {
            page.creditsValue.textContent = '0';
            page.lootboxValue.textContent = '0';
            page.buyButton.disabled = true;
            page.openButton.disabled = true;
            setResult(page, 'error', 'Log in required', 'Create an account or log in before buying loot crates.');
            return;
        }

        page.creditsValue.textContent = format(user.credits);
        page.lootboxValue.textContent = format(user.lootboxes);
        page.levelValue.textContent = format(user.level);
        page.xpValue.textContent = format(user.xp);
        page.streakValue.textContent = format(user.streak);
        page.buyButton.disabled = Number(user.credits ?? 0) < CRATE_COST;
        page.openButton.disabled = Number(user.lootboxes ?? 0) < 1;
    }

    function bindCrateActions() {
        const page = getPage();
        if (!page.buyButton || !page.openButton) return;

        if (page.buyButton.dataset.ready !== 'true') {
            page.buyButton.dataset.ready = 'true';
            page.buyButton.addEventListener('click', () => {
                const page = getPage();
                const result = buyLootbox(CRATE_COST);
                if (!result.ok) {
                    setResult(page, 'error', 'Purchase failed', result.error ?? 'Unable to buy a crate.');
                    renderUser();
                    return;
                }

                animateCrate(page, 'buying');
                setResult(page, 'success', 'Crate purchased', `You spent ${CRATE_COST} credits and added 1 loot crate.`);
                renderUser(result.user);
            });
        }

        if (page.openButton.dataset.ready !== 'true') {
            page.openButton.dataset.ready = 'true';
            page.openButton.addEventListener('click', () => {
                const page = getPage();
                const result = openLootbox();
                if (!result) {
                    setResult(page, 'error', 'No crate opened', 'You need at least 1 loot crate before opening.');
                    renderUser();
                    return;
                }

                page.buyButton.disabled = true;
                page.openButton.disabled = true;
                animateCrate(page, 'opening');
                setResult(page, 'success', 'Opening crate...', 'Your reward is being revealed.');

                finishAnimationSoon(() => {
                    const page = getPage();
                    if (!page.crateVisual) return;
                    page.crateVisual.classList.remove('opening');
                    page.crateVisual.classList.add('opened');
                    setResult(page, 'success', result.reward.label, 'Reward added to your account.');
                    renderUser(result.user);
                });
                renderUser(result.user);
            });
        }
    }

    bindCrateActions();
    renderUser();
    document.addEventListener('astro:page-load', () => {
        bindCrateActions();
        renderUser();
    });
</script>
</BaseLayout>



