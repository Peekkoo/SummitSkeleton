---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/dashboard.css';
---

<BaseLayout title="Dashboard - Summit">
<main class="dashboard-shell">
    <nav class="dashboard-navigation" aria-label="Dashboard navigation">
        <a class="brand" href="/">
            <h1>Summit</h1>
        </a>
        <div class="navigation-actions">
            <a class="navigation-link" href="/credits">Credits</a>
            <a class="navigation-link" href="/loot-crates">Loot Crates</a>
            <a class="navigation-link" href="/leaderboard">Leaderboard</a>
            <button class="navigation-link" type="button" data-signout-button>Sign Out</button>
        </div>
    </nav>

    <section class="hero-panel" aria-labelledby="dashboard-title">
        <div class="hero-copy">
            <span class="eyebrow">Dashboard</span>
            <h2 id="dashboard-title">Welcome back, <span id="user-name">Loading</span></h2>
            <p>Choose a study path, track progress, earn XP and credits, open loot crates, and climb the leaderboard as the backend comes online.</p>
            <div class="hero-actions">
                <a class="primary-action" href="#study-paths">Start Studying</a>
                <a class="ghost-action" href="#progress">View Progress</a>
            </div>
        </div>

        <aside class="summit-meter" aria-label="Level progress">
            <div class="meter-header">
                <div>
                    <span class="panel-label">Current Level</span>
                    <strong id="level-value">--</strong>
                </div>
                <span id="xp-next">-- / -- XP</span>
            </div>
            <div class="meter-track" aria-hidden="true">
                <div class="meter-fill" id="xp-meter"></div>
            </div>
            <p class="section-intro">Next reward: loot crate and leaderboard boost.</p>
        </aside>
    </section>

    <section class="statistics-grid" aria-label="Account stats">
        <article class="statistic-card">
            <span class="statistic-label">XP</span>
            <strong id="xp-value">--</strong>
        </article>
        <article class="statistic-card">
            <span class="statistic-label">Credits</span>
            <strong id="credits-value">--</strong>
        </article>
        <article class="statistic-card">
            <span class="statistic-label">Streak</span>
            <strong><span id="streak-value">--</span>d</strong>
        </article>
        <article class="statistic-card">
            <span class="statistic-label">Loot Crates</span>
            <strong><a class="statistic-link" id="loot-link" href="/loot-crates"><span id="loot-value">--</span></a></strong>
        </article>
    </section>

    <div class="dashboard-grid">
        <div>
            <section class="content-panel" id="study-paths" aria-labelledby="study-title">
                <div class="panel-heading">
                    <div>
                        <span class="panel-label">Options</span>
                        <h3 id="study-title">Study Paths</h3>
                    </div>
                    <a class="compact-action" href="/knowledge-bites">Knowledge Bites</a>
                </div>

                <div class="path-grid">
                    <a class="path-card" href="#life-skills">
                        <span class="path-icon">
                            <img src="/assets/images/life-skills.png" alt="" loading="lazy">
                        </span>
                        <div>
                            <span class="path-metadata">Practical track</span>
                            <h4>Life Skills</h4>
                        </div>
                        <p>Short lessons for habits, money, communication, planning, and everyday confidence.</p>
                    </a>
                    <a class="path-card" href="/knowledge">
                        <span class="path-icon">
                            <img src="/assets/images/knowledge.png" alt="" loading="lazy">
                        </span>
                        <div>
                            <span class="path-metadata">Core learning</span>
                            <h4>Knowledge</h4>
                        </div>
                        <p>Focused study sets for facts, concepts, memory, and quick review sessions.</p>
                    </a>
                    <a class="path-card" href="#custom-studies">
                        <span class="path-icon">
                            <img src="/assets/images/loot-crate.png" alt="" loading="lazy">
                        </span>
                        <div>
                            <span class="path-metadata">Personal plan</span>
                            <h4>Custom Studies</h4>
                        </div>
                        <p>Build your own topic list and turn it into repeatable practice blocks.</p>
                    </a>
                    <a class="path-card" href="/knowledge-bites">
                        <span class="path-icon">
                            <img src="/assets/images/knowledge-bites.png" alt="" loading="lazy">
                        </span>
                        <div>
                            <span class="path-metadata">Daily feed</span>
                            <h4>Knowledge Bites</h4>
                        </div>
                        <p>Browse quick facts and info cards when you want a light study session.</p>
                    </a>
                </div>
            </section>

            <section class="content-panel" id="progress" aria-labelledby="progress-title" style="margin-top: 1.5rem;">
                <div class="panel-heading">
                    <div>
                        <span class="panel-label">Progress Tracking</span>
                        <h3 id="progress-title">Today&apos;s Climb</h3>
                    </div>
                    <a class="compact-action" href="/leaderboard">Compare Rank</a>
                </div>

                <div class="progress-stack">
                    <article class="activity-item">
                        <div class="activity-top">
                            <div>
                                <strong>Life Skills: Money Basics</strong>
                                <p>2 of 4 lessons complete</p>
                            </div>
                            <span class="activity-metadata">+120 XP</span>
                        </div>
                        <div class="progress-line" aria-hidden="true"><span style="width: 50%;"></span></div>
                    </article>
                    <article class="activity-item">
                        <div class="activity-top">
                            <div>
                                <strong>Knowledge: Memory Sprint</strong>
                                <p>7 quick facts reviewed</p>
                            </div>
                            <a class="compact-action" href="/knowledge">Study Knowledge</a>
                        </div>
                        <div class="progress-line" aria-hidden="true"><span style="width: 72%;"></span></div>
                    </article>
                    <article class="activity-item">
                        <div class="activity-top">
                            <div>
                                <strong>Custom Studies: Biology Terms</strong>
                                <p>Ready for your next session</p>
                            </div>
                            <span class="activity-metadata">Crate at 5 lessons</span>
                        </div>
                        <div class="progress-line" aria-hidden="true"><span style="width: 35%;"></span></div>
                    </article>
                </div>
            </section>
        </div>
    </div>
</main>

<script>
    import { getCurrentUser, setupSignOutButtons } from '../scripts/auth.js';

    function renderDashboard() {
        const user = getCurrentUser();

        if (!user) {
            window.location.href = '/login';
            return;
        }

        const xp = Number(user.xp ?? 0);
        const level = Number(user.level ?? 1);
        const nextLevelXp = Math.max(level * level * 100, 100);
        const meterWidth = Math.min(Math.round((xp / nextLevelXp) * 100), 100);

        document.getElementById('user-name')!.textContent = user.username;
        document.getElementById('xp-value')!.textContent = xp.toLocaleString();
        document.getElementById('credits-value')!.textContent = Number(user.credits ?? 0).toLocaleString();
        document.getElementById('streak-value')!.textContent = Number(user.streak ?? 0).toLocaleString();
        document.getElementById('loot-value')!.textContent = Number(user.lootboxes ?? 0).toLocaleString();
        document.getElementById('level-value')!.textContent = level.toLocaleString();
        document.getElementById('xp-next')!.textContent = `${xp.toLocaleString()} / ${nextLevelXp.toLocaleString()} XP`;
        (document.getElementById('xp-meter') as HTMLElement).style.width = `${meterWidth}%`;
    }

    renderDashboard();
    setupSignOutButtons();
    document.addEventListener('astro:page-load', renderDashboard);
    document.addEventListener('astro:page-load', setupSignOutButtons);
</script>
</BaseLayout>



